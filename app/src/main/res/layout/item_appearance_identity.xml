<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp"
    android:background="@drawable/bg_appearance_item">

    <ImageView
        android:id="@+id/iv_identity_icon"
        android:layout_width="@dimen/app_icon_preview_size"
        android:layout_height="@dimen/app_icon_preview_size"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/tv_identity_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/open_sans"
        android:textSize="12sp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>