<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bkgd_blue_rect"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!--
            Dismiss button — only visible once TX is complete, failed, or cancelled.
            Hidden during active transmission to prevent accidental dismissal.
        -->
        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/stop_button"
            android:src="@drawable/btn_close_small_24"
            android:visibility="gone"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/transmit_via_radio"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Spacer balances the close button and keeps the title centered -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />

    </LinearLayout>

    <!-- ── Scrollable content ──────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Frequency section ─────────────────────────────────────── -->
            <!--
                Shown before TX starts with the stepper enabled.
                Once transmission begins, stepper is disabled and becomes read-only.
            -->
            <LinearLayout
                android:id="@+id/tx_frequency_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/section_bkgd_dark_grey_8"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/tx_frequency_title_khz"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <!-- Stepper row: [−] [EditText] [+] -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_tx_freq_minus"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/btn_bkgd_transparent_56"
                        android:padding="0dp"
                        android:text="−"
                        android:textSize="20sp" />

                    <EditText
                        android:id="@+id/et_tx_frequency"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/section_bkgd_dark_grey_8"
                        android:gravity="center"
                        android:inputType="number"
                        android:padding="8dp"
                        android:textColor="@color/white"
                        android:textSize="18sp" />

                    <Button
                        android:id="@+id/btn_tx_freq_plus"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/btn_bkgd_transparent_56"
                        android:padding="0dp"
                        android:text="+"
                        android:textSize="20sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Encryption mode ────────────────────────────────────────────── -->
            <!--
                Checkbox defaults to unchecked (encrypted). Disabled once TX starts.
                Warning icon appears only when encryption is disabled.
                When this becomes a dropdown, only this section changes.
            -->
            <LinearLayout
                android:id="@+id/encryption_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/section_bkgd_dark_grey_8"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <CheckBox
                    android:id="@+id/cb_disable_encryption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/white"
                    android:checked="false"
                    android:text="@string/send_without_encryption"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <!--
                    Warning icon — visible only when encryption is disabled.
                    Communicates risk without being alarming when encrypted (default).
                -->
                <ImageView
                    android:id="@+id/iv_encryption_warning"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/encryption_warning"
                    android:src="@drawable/ic_warning"
                    android:visibility="gone"
                    app:tint="@color/tangerine" />

            </LinearLayout>

            <!-- ── Message preview ───────────────────────────────────────── -->
            <!--
                Plaintext is already in memory when the sheet opens.
                Visible throughout all states — this is what's being sent.
                Truncated to 2 lines; full text accessible by scrolling the sheet.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/section_bkgd_dark_grey_8"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="@string/message_label"
                    android:textColor="@color/coolGrey"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_message_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- ── State icon + status text ──────────────────────────────── -->
            <ImageView
                android:id="@+id/iv_state_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:contentDescription="@string/transmit_status"
                android:src="@drawable/ic_nahoft_radio_transmit"
                app:tint="@color/tangerine" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/tap_start_to_transmit"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- ── Progress section ───────────────────────────────────────── -->
            <!--
                Hidden in Idle state.
                Shows spot step indicator, symbol progress bar, and countdown.
                Managed by showProgressSection() / hideProgressSection().
            -->
            <LinearLayout
                android:id="@+id/progress_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/section_bkgd_dark_grey_8"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone">

                <!-- Spot step indicator row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/packets_label"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_spot_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/tangerine"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!--
                    Dot step indicator — populated programmatically in the fragment.
                    One dot per spot; current spot is tangerine, completed are white,
                    remaining are coolGrey.
                -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:id="@+id/ll_spot_dots"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal" />

                </HorizontalScrollView>

                <!-- Symbol progress bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/symbols_label"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_symbol_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/tangerine"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_symbols"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginBottom="16dp"
                    android:max="162"
                    android:progress="0"
                    android:progressBackgroundTint="#40FFFFFF"
                    android:progressTint="@color/tangerine" />

                <!-- Countdown to next TX window — shown only in WaitingForWindow state -->
                <LinearLayout
                    android:id="@+id/countdown_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:contentDescription="@string/next_tx_window"
                        android:src="@drawable/ic_access_time"
                        app:tint="@color/coolGrey" />

                    <TextView
                        android:id="@+id/tv_countdown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:textColor="@color/coolGrey"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Terminal state card ────────────────────────────────────── -->
            <!--
                Shown only for Complete, Failed, and Cancelled states.
            -->
            <LinearLayout
                android:id="@+id/terminal_state_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/section_bkgd_dark_grey_8"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_terminal_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_terminal_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:textColor="@color/coolGrey"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Primary action button — always visible below scroll ────────── -->
    <!--
        Label and behavior change with state:
        Idle/Preparing/WaitingForWindow/TransmittingSpot/SwitchingToRx → "Stop"
        Complete/Failed/Cancelled → "Dismiss" (close button also appears in header)
        In Idle, this button is "Start" and launches the TX pipeline.
    -->
    <Button
        android:id="@+id/btn_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/btn_bkgd_tangerine_8"
        android:text="@string/start_transmission"
        android:textColor="@color/white" />

</LinearLayout>