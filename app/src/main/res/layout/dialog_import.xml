<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:paddingTop="@dimen/padding_three_quarters"
    android:paddingBottom="@dimen/padding_three_quarters">

    <EditText
        android:id="@+id/import_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_bkgd_light_grey_outline_8"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:minLines="5"
        android:padding="@dimen/padding_half"
        android:textColor="@color/royalBlueDark"
        tools:hint="@string/import_dialog_hint_key" />

    <!-- Button row, right-aligned (Material dialog convention).
         Order left-to-right in LTR: Cancel, Paste, Import.
         LinearLayout flips this automatically in RTL locales like Farsi.
         wrap_content on each button prevents text wrapping in any language. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_three_quarters"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cornerRadius="24dp"
            android:text="@string/button_label_cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_paste"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_quarter"
            app:cornerRadius="24dp"
            android:text="@string/paste_from_clipboard" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_import"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_quarter"
            app:cornerRadius="24dp"
            android:text="@string/button_label_import" />
    </LinearLayout>
</LinearLayout>