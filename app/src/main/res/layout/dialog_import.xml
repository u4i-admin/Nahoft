<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/padding_standard"
    android:paddingEnd="@dimen/padding_standard"
    android:paddingTop="@dimen/padding_three_quarters"
    android:paddingBottom="@dimen/padding_three_quarters">

    <!-- Paste target. inputType=textMultiLine enables line wrapping and lets the
         IME's Enter key insert a newline rather than dismissing. minLines gives
         a comfortable paste area without forcing a fixed pixel height. -->
    <EditText
        android:id="@+id/import_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_bkgd_light_grey_outline_8"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:minLines="5"
        android:padding="@dimen/padding_half"
        android:textColor="@color/royalBlueDark"
        tools:hint="@string/import_dialog_hint_key" />

    <!-- Button row. Order is Cancel — Paste — Import (left to right in LTR;
         LinearLayout flips this automatically in RTL locales like Farsi).
         Each button has weight=1 so they share width equally. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_three_quarters"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/padding_quarter"
            android:text="@string/button_label_cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_paste"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/padding_quarter"
            android:layout_marginEnd="@dimen/padding_quarter"
            android:text="@string/paste_from_clipboard" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_import"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/padding_quarter"
            android:text="@string/button_label_import" />
    </LinearLayout>
</LinearLayout>